# Database Configuration (local development — localhost)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=USER
DB_PASSWORD=PASSWORD
DB_NAME=DATABASE_NAME
DATABASE_URL=mysql://USER:PASSWORD@127.0.0.1:3306/DATABASE_NAME
DATABASE_POOL_SIZE=5

# Live database (ibo.garden production — cPanel MariaDB, remote from Cloudflare)
# Use your cPanel server hostname (NOT localhost). Enable Remote MySQL in cPanel.
LIVE_DB_HOST=premium30.bambooempireinc.com
LIVE_DB_PORT=3306
LIVE_DB_USER=cpanel_db_user
LIVE_DB_PASSWORD=cpanel_db_password
LIVE_DB_NAME=cpanel_db_name
LIVE_DATABASE_URL=mysql://USER:PASSWORD@premium30.bambooempireinc.com:3306/DATABASE_NAME

# Optional override: local | live (auto-detects from NODE_ENV + VITE_SITE_URL if unset)
# DATABASE_TARGET=local

# Admin (dev wallet only — no password or session secret)
ADMIN_DEV_WALLET=GAinSTufAma6Z53W1EveJPYSXh2bJySw4k2kZ1TMoLF3
VITE_ADMIN_DEV_WALLET=GAinSTufAma6Z53W1EveJPYSXh2bJySw4k2kZ1TMoLF3
ADMIN_EMAIL=dougbutner@gmail.com

# User sessions + Google OAuth (any length accepted; short values are auto-extended to 32+ chars)
USER_SESSION_SECRET=generate-another-long-random-string
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://ibo.garden/api/auth/google/callback

# Site
VITE_SITE_URL=https://ibo.garden

# Email notifications (configure one provider)
MAIL_FROM=ibo.garden <notifications@ibo.garden>
# Resend (recommended)
RESEND_API_KEY=
# SMTP (cPanel / alternative)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# Solana / GAINE (existing)
SOLANA_RPC_URL=
VITE_GAINE_MINT=

# External reward routing API (Bearer token or X-Reflection-Api-Key header)
REFLECTION_API_KEY=
